# --- Groww auth (pick ONE method) ---

GROWW_API_KEY=
GROWW_TOTP_SECRET=
GROWW_TOTP=
# GROWW_API_SECRET=

ORB_SYMBOL=NIFTY26APRFUT
# Futures-only mode: orders always use ORB_SYMBOL.

# Orders & history use Groww FNO segment only (no equity cash / MCX in this repo).
FNO_PRODUCT=MIS
ORB_CAPITAL=100000
ORB_RISK_PCT=0.01
ORB_RR=2.0

# --- Alerts (no broker orders) ---
# Set ORB_ALERTS_ONLY=1 to never call place_order (even with `live --execute`).
ORB_ALERTS_ONLY=1
# Token from @BotFather (format 123456789:AAH… — no spaces). If you see "401 Unauthorized", the token is wrong or revoked: /mybots → API Token → copy again.
TELEGRAM_BOT_TOKEN=
# Your user id or group id (message the bot first, then getUpdates)
TELEGRAM_CHAT_ID=

# Streamlit UI writes niftybot_ui_prefs.json: bot_enabled, telegram_alerts_enabled, execute_orders,
# orb_symbol and fno_product (MIS|NRML). Instrument is fixed to futures.
# Live bot appends alerts to niftybot_alerts.sqlite3 (and Telegram when tokens are set).

# --- Session ORB v2 (5m backtest / tune) ---
# Historical data: Groww get_historical_candles + groww_symbol (see https://groww.in/trade-api/docs/python-sdk/backtesting ).
# Long backtests: `fetch_historical_5m` auto-chunks (ORB_HIST_CHUNK_DAYS per request, default 14). Raise if your tier allows more per call.
# ORB_HIST_CHUNK_DAYS=14
# 5m candles: use get_expiries / get_contracts from that doc to list option groww symbols.
# ORB_ORB_START=09:15
# ORB_ORB_END=09:45
# ORB_MIN_ORB_CANDLES=6
# ORB_MIN_CONFIRMATIONS=2
# ORB_VOLUME_MA_MULT=1.12
# ORB_BODY_RATIO=0.32
# ORB_REQUIRE_VWAP_SIDE=1
# ORB_REQUIRE_EMA=0
# ORB_SKIP_CHOPPY=0
# ORB_CHOPPY_MAX=0.0016
# ORB_SL_BUFFER_ATR=0.12
# ORB_SL_CAP_ATR=1.35
# ORB_MAX_TRADES_PER_DAY=2
# ORB_ONE_TRADE_PER_DAY=0
